# ChatMRPT Environment Variables
# ================================
# QUICK START:
# 1. Copy this file: cp .env.example .env
# 2. Add your OpenAI API key below (line 15)
# 3. Run: python run.py
# ================================

# ===========================================
# REQUIRED - You MUST set this to run the app
# ===========================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ===========================================
# Flask Configuration (defaults work fine)
# ===========================================
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True

# ===========================================
# Database Configuration
# ===========================================
# SQLite for local development (no setup needed)
DATABASE_URL=sqlite:///instance/chatmrpt.db

# ===========================================
# Application Folders (auto-created)
# ===========================================
UPLOAD_FOLDER=instance/uploads
REPORT_FOLDER=instance/reports
LOG_FOLDER=instance/logs
MAX_CONTENT_LENGTH=33554432

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# Authentication (disabled for local dev)
# ===========================================
DISABLE_AUTH=true

# ===========================================
# OpenAI Model Configuration
# ===========================================
OPENAI_MODEL_NAME=gpt-4o
OPENAI_MODEL_FALLBACKS=gpt-4o,gpt-4o-mini
ENABLE_VISION_EXPLANATIONS=true

# ===========================================
# OPTIONAL - Advanced Features (not needed for basic use)
# ===========================================

# Semantic Router (for intelligent message routing)
SEMANTIC_ROUTER_ENABLED=true
SEMANTIC_ROUTER_ENCODER=openai  # 'openai' or 'local'
SEMANTIC_ROUTER_LLM_FALLBACK=true

# Redis (only needed for multi-worker sessions)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# CHATMRPT_USE_REDIS_MEMORY=0
# CHATMRPT_REDIS_MEMORY_STRICT=0

# Arena Mode (for model comparison - requires Ollama)
# USE_ARENA=false
# ARENA_MODE=disabled

# Google OAuth (for production authentication)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# DHIS2 Data Cleaner
# ===========================================
# Fixes duplicate columns and mojibake in DHIS2 pivot table exports (e.g. Kwara).
# Without this, TPR burden numbers may be wrong (only 2020 data used instead of all years).
# Options: off | log_only | full
# Set to 'full' for production. Safe to enable — falls back to uncleaned data on error.
CHATMRPT_DHIS2_CLEANER=full

# ===========================================
# Production Settings (ignore for local dev)
# ===========================================
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=300
# ===========================================
# WhatsApp Integration (Twilio)
# ===========================================
TWILIO_ACCOUNT_SID=your-account-sid-here
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Required for production WhatsApp deployments.
CHATMRPT_WHATSAPP_REQUIRE_REDIS=1
CHATMRPT_WHATSAPP_REQUIRE_QUEUE=1
CHATMRPT_WHATSAPP_QUEUE_NAME=whatsapp
CHATMRPT_WHATSAPP_JOB_TIMEOUT=3600
CHATMRPT_WHATSAPP_SENDER_LOCK_TTL=3900
CHATMRPT_WHATSAPP_SENDER_LOCK_WAIT=1800
